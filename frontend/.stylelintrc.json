{
    "extends": [
        "stylelint-config-standard",
        "stylelint-config-css-modules"
    ],
    "rules": {
        "selector-class-pattern": [
            "^[a-z][a-zA-Z0-9]+$",
            {
                "message": "Class slector needs to be camelCase for CSS modules"
            }
        ]
    }
}