{
    "$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "includes": [
            "**/src/**/*",
            "**/.vscode/**/*",
            "**/index.html",
            "**/vite.config.ts",
            "!**/src/routeTree.gen.ts",
            "!**/src/styles.css"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4
    },
    "assist": { "actions": { "source": { "organizeImports": "on" } } },
    "linter": {
        "rules": {
            "complexity": {
                "noExcessiveCognitiveComplexity": "error",
                "noForEach": "error",
                "useMaxParams": "error",
                "noExcessiveLinesPerFunction": {
                    "options": {
                        "skipBlankLines": true
                    },
                    "level": "error"
                }
            },
            "suspicious": {
                "noConsole": "error"
            },
            "style": {
                "noShoutyConstants": "error",
                "useNamingConvention": "error",
                "useFilenamingConvention": {
                    "level": "error",
                    "options": {
                        "strictCase": true,
                        "requireAscii": true,
                        "filenameCases": [
                            "camelCase",
                            "PascalCase",
                            "kebab-case"
                        ]
                    }
                },
                "useConsistentBuiltinInstantiation": "error",
                "noDefaultExport": "error",
                "noParameterAssign": "error"
            }
        }
    },
    "overrides": [
        {
            "includes": ["*.config.ts", "*.config.js", "src/integrations/**"],
            "linter": {
                "rules": {
                    "style": {
                        "noDefaultExport": "off"
                    }
                }
            }
        }
    ]
}
